    },
    "fileTriggers": {
      "pathPatterns": ["server/**/domain/**/*.ts"],
      "contentPatterns": ["class.*Model", "ValueObject", "extends.*Model"]
    },
    "skill": ".claude/skills/domain-modeling.md"
  },
